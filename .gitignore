# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
.node_repl_history

# Environment & secrets
.env
.env.*
!.env.example
.envrc

# Certificates (generated per deploy)
certs/

