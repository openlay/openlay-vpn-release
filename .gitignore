.DS_Store
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*.swn
*.bak
*.orig
*.rej
.fleet/
.zed/

# Build artifacts (release-repo ships its own pre-built binaries — see
# olv-agent-bsd/bin/ — so don't ignore those; only catch transients).
*.tgz
*.tar.gz
*.tar
*.zip
dist-tmp/
.cache/
.parcel-cache/
*.tsbuildinfo
coverage/
.nyc_output/

# Logs
*.log
logs/

# Test/dev artefacts
*.pid
*.seed

# SSH keys / private creds
.ssh/
id_rsa
id_ed25519
*.pem.private

# Python (in case any tooling lands)
__pycache__/
*.pyc
*.pyo
.venv/
.pytest_cache/

# Local junk that's never wanted in this repo
*.tmp
*.tmp.*
