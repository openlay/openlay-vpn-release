# OpenLay VPN Agent Configuration

# Authentication (legacy, kept for enrollment fallback)
API_TOKEN=your-api-token

# WireGuard
WG_CONFIG_DIR=/etc/wireguard

# Audit
AUDIT_LOG_FILE=./audit.log
AUDIT_LOG_MAX=1000

# Management Server
MANAGEMENT_API_URL=https://mng.livevpn.com:3084/api
MANAGEMENT_API_TOKEN=
MANAGEMENT_CA_CERT=
HEARTBEAT_INTERVAL=30

# Enrollment token (cert-based auth — recommended)
ENROLLMENT_TOKEN=your-enrollment-token

# IP Whitelist (empty = allow all)
ALLOWED_IPS=

# Docker deployment:
#   1. Copy this file to .env and fill in values
#   2. Run: docker compose up -d
#   3. Logs: docker compose logs -f
